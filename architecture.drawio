                <mxCell id="91" value="&lt;p&gt;&lt;span style=&quot;font-size: 8px;&quot;&gt;Creato README.md con stack, architettura, struttura, setup, roadmap — per garantire continuità tra sessioni di lavoro diverse.&lt;/span&gt;&lt;/p&gt;" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;" vertex="1" parent="90">
