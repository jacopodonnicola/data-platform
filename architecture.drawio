                    </mxGeometry>
                </mxCell>
                <mxCell id="53" value="&lt;p&gt;&lt;span style=&quot;color: rgb(63, 63, 63); font-size: 8px; background-color: transparent;&quot;&gt;Creato &lt;b&gt;ingestion/exploration.ipynb&lt;/b&gt;. Per ciascun endpoint:&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;color: rgb(63, 63, 63); font-size: 8px; background-color: transparent;&quot;&gt;- chiamata API con requests&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 8px;&quot;&gt;- analisi struttura JSON&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 8px;&quot;&gt;- trasformazione in DataFrame con pandas&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 8px;&quot;&gt;- pulizia tipi (stringhe → float/int/datetime)&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 8px;&quot;&gt;- aggiunta colonna ticker&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 8px;&quot;&gt;- salvataggio Parquet locale di verifica&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;b style=&quot;color: rgb(63, 63, 63); font-size: 8px; background-color: transparent;&quot;&gt;&lt;br&gt;Scoperta struttura dati&lt;/b&gt;&lt;span style=&quot;color: rgb(63, 63, 63); font-size: 8px; background-color: transparent;&quot;&gt;:&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;background-color: transparent; color: rgb(63, 63, 63); font-size: 8px;&quot;&gt;TIME_SERIES_DAILY → serie temporale annidata, 100 giorni&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 8px;&quot;&gt;OVERVIEW → dizionario piatto, 55 campi fondamentali&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 8px;&quot;&gt;EARNINGS → due liste (annualEarnings, quarterlyEarnings)&lt;/span&gt;&lt;/p&gt;" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;" parent="52" vertex="1">
                    <mxGeometry y="30" width="140" height="440" as="geometry"/>
                </mxCell>
                <mxCell id="61" value="" style="shape=singleArrow;whiteSpace=wrap;html=1;arrowWidth=0.4;arrowSize=0.4;fontStyle=0;startSize=30;" parent="52" vertex="1">
                    <mxGeometry y="470" width="140" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="57" value="Formalizzazione codice script" style="swimlane;fontStyle=0;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=1;marginBottom=0;whiteSpace=wrap;html=1;" parent="1" vertex="1" collapsed="1">
                    <mxGeometry x="200" y="120" width="120" height="40" as="geometry">
                        <mxRectangle x="200" y="120" width="140" height="210" as="alternateBounds"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="58" value="&lt;p&gt;&lt;span style=&quot;font-size: 8px;&quot;&gt;In Ingestion / , creato:&lt;br&gt;- extractors / prices.py --&amp;gt; chiamata API, ritorna JSON grezzo&lt;br&gt;- transformers / prices.py --&amp;gt; Da JSON a dataframe pulito e tipizzato&lt;br&gt;- loaders / minio_loader.py -&amp;gt; salva Dataframe come Parquet su MinIO (via io.BytesIO)&amp;nbsp;&lt;br&gt;- main.py -&amp;gt; orchestra extract + transform + load per ogni ticker&lt;/span&gt;&lt;/p&gt;" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;" parent="57" vertex="1">
                    <mxGeometry y="30" width="140" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="63" value="Rate limiting e errori API" style="swimlane;fontStyle=0;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=1;marginBottom=0;whiteSpace=wrap;html=1;" parent="1" vertex="1" collapsed="1">
                    <mxGeometry x="40" y="120" width="120" height="40" as="geometry">
                        <mxRectangle x="40" y="120" width="140" height="140" as="alternateBounds"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="64" value="&lt;p&gt;&lt;span style=&quot;font-size: 8px;&quot;&gt;time.sleep(2) tra le chiamate (limite Alpha Vantage: 1 richiesta/secondo)&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 8px;&quot;&gt;funzione is_valid_response() per rilevare risposte di errore/rate-limit prima di trasformarle&lt;/span&gt;&lt;/p&gt;" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;" parent="63" vertex="1">
                    <mxGeometry y="30" width="140" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="68" value="Ingesiton completa" style="swimlane;fontStyle=0;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=1;marginBottom=0;whiteSpace=wrap;html=1;" parent="1" vertex="1" collapsed="1">
