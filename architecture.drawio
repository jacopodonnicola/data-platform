                <mxCell id="48" value="&lt;p&gt;&lt;font style=&quot;font-size: 8px;&quot;&gt;Scelto &lt;b&gt;uv &lt;/b&gt;come package manager&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 8px;&quot;&gt;&lt;b&gt;uv init&lt;/b&gt; per generare &lt;b&gt;pyproject.toml&lt;/b&gt; e &lt;b&gt;uv.lock&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 8px;&quot;&gt;&lt;b&gt;uv sync&lt;/b&gt; come comando standard per creare/aggiornare il venv su qualsiasi macchina (sostituendo uv venv manuale)&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 8px;&quot;&gt;Standardizzato su Python 3.12 (per coerenza tra Codespaces e locale)&lt;/font&gt;&lt;/p&gt;" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;" parent="47" vertex="1">
