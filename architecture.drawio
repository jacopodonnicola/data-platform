                <mxCell id="96" value="&lt;p&gt;&lt;span style=&quot;font-size: 8px;&quot;&gt;Aggiunte dipendenze: duckdb, dbt-core, dbt-duckdb&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 8px;&quot;&gt;dbt init&amp;nbsp;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 8px;&quot;&gt;profiles.yml configurato con path: {{ env_var(&#39;DUCKDB_PATH&#39;) }} per portabilità tra macchine&lt;/span&gt;&lt;/p&gt;" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;" vertex="1" parent="95">
