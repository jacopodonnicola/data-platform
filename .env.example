# Alpha Vantage - ottieni la tua chiave su https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_api_key_here

# MinIO - valori di default per sviluppo locale
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# DuckDB - percorso del database 
DUCKDB_PATH=/path/to/data-platform/warehouse/warehouse.duckdb

# Percorso del progetto
PROJECT_PATH=/path/to/data-platform